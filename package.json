{
  "name": "@manufosela/ai-components",
  "version": "0.1.0",
  "private": true,
  "description": "Monorepo of @manufosela AI web components built with Lit, powered by Chrome Built-in AI. 100% JavaScript + JSDoc (no TypeScript). Components detect AI capability at mount time and gracefully fall back to a traditional HTML form when AI is unavailable.",
  "type": "module",
  "packageManager": "pnpm@10.20.0",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "pnpm -r --filter \"./packages/*\" run build",
    "build:types": "pnpm -r --filter \"./packages/*\" run build:types",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint --no-error-on-unmatched-pattern \"packages/*/src/**/*.js\" \"packages/*/test/**/*.js\" \"apps/**/*.js\"",
    "lint:fix": "pnpm lint --fix",
    "format": "prettier --write --ignore-unknown \"**/*.{js,json,md,astro,yml,yaml}\"",
    "format:check": "prettier --check --ignore-unknown \"**/*.{js,json,md,astro,yml,yaml}\"",
    "site:dev": "pnpm --dir apps/site dev",
    "site:build": "pnpm --dir apps/site build",
    "site:preview": "pnpm --dir apps/site preview",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && changeset publish",
    "prepare": "husky"
  },
  "keywords": [
    "lit",
    "web-components",
    "ai",
    "chrome-ai",
    "gemini-nano",
    "prompt-api",
    "monorepo",
    "javascript",
    "jsdoc"
  ],
  "author": {
    "name": "Mánu Fosela",
    "email": "mjfosela@gmail.com",
    "url": "https://github.com/manufosela"
  },
  "license": "MIT",
  "homepage": "https://github.com/manufosela/ai-components#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/manufosela/ai-components.git"
  },
  "bugs": {
    "url": "https://github.com/manufosela/ai-components/issues"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.1",
    "@eslint/js": "^9.0.0",
    "@vitest/coverage-v8": "4.1.5",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-jsdoc": "^50.6.0",
    "husky": "^9.0.0",
    "jsdom": "29.0.2",
    "lint-staged": "16.4.0",
    "prettier": "^3.3.0",
    "typescript": "^5.5.0",
    "vitest": "4.1.5"
  }
}
