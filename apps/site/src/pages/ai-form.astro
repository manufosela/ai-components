---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="<ai-form> demo">
  <main class="demo">
    <ai-form id="demo" language="es-ES" voice-input voice-output>
      <form>
        <label>
          <span>Nombre</span>
          <input name="nombre" ai-extract="nombre completo" required />
        </label>
        <label>
          <span>Teléfono</span>
          <input
            name="telefono"
            type="tel"
            ai-extract="número de móvil"
            ai-validate="spanish mobile (9 digits, starting with 6 or 7)"
            required
          />
        </label>
        <label>
          <span>Email</span>
          <input name="email" type="email" ai-extract="dirección de email" required />
        </label>
        <label>
          <span>Comentario</span>
          <textarea
            name="about"
            ai-extract="comentario libre"
            ai-validate="tono profesional, máximo 200 palabras"
            rows="2"></textarea>
        </label>
        <label>
          <span>CV (PDF)</span>
          <input name="cv" type="file" accept="application/pdf" required />
        </label>
        <label class="inline">
          <input name="tos" type="checkbox" required />
          <span>Acepto los términos y condiciones</span>
        </label>
      </form>
    </ai-form>

    <details class="help">
      <summary>¿Qué es esto? / About this demo</summary>
      <p>
        <code>&lt;ai-form&gt;</code> wraps a regular HTML <code>&lt;form&gt;</code> and layers a
        conversational chat on top when Chrome's Built-in AI is available. The AI extracts data
        from your reply and fills the fields below; manual ones (file, checkbox, selects…) stay
        for you to handle by hand. When every <code>required</code> field is satisfied, the
        Submit button appears.
      </p>
      <p>
        Needs Chrome / Edge 138+ with
        <a href="https://developer.chrome.com/docs/ai/get-started" target="_blank" rel="noopener"
          >Built-in AI flags</a
        >
        enabled. If the banner shows "Enable AI", click it to trigger the one-time Gemini Nano
        download (~2 GB).
      </p>
    </details>

    <details class="event-log">
      <summary>Event log</summary>
      <pre id="event-log" aria-live="polite">(events will appear here)</pre>
    </details>
  </main>

  <style>
    .demo {
      max-width: 720px;
      margin: 2rem auto;
      padding: 0 1rem;
    }
    /* Make the slotted form compact/secondary — it's the ledger, not the hero. */
    ai-form form {
      display: grid;
      gap: 0.35rem;
      font-size: 0.92rem;
    }
    ai-form label {
      display: grid;
      gap: 0.15rem;
    }
    ai-form label.inline {
      display: flex;
      flex-direction: row;
      align-items: center;
      gap: 0.5rem;
    }
    ai-form label span {
      font-size: 0.8rem;
      color: var(--muted);
    }
    ai-form input,
    ai-form textarea {
      font: inherit;
      padding: 0.35rem 0.5rem;
      border: 1px solid var(--border);
      border-radius: 4px;
      background: var(--bg);
      color: var(--fg);
    }
    .help,
    .event-log {
      margin-top: 2rem;
      font-size: 0.9rem;
      color: var(--muted);
    }
    .help summary,
    .event-log summary {
      cursor: pointer;
      padding: 0.25rem 0;
    }
    .help p {
      margin: 0.5rem 0;
    }
    #event-log {
      max-height: 240px;
      overflow-y: auto;
      padding: 0.5rem;
      border: 1px solid var(--border);
      border-radius: 4px;
      background: var(--card);
      font-size: 0.75rem;
      white-space: pre-wrap;
    }
  </style>

  <script>
    import '@manufosela/ai-form';

    const form = /** @type {any} */ (document.getElementById('demo'));
    const log = /** @type {HTMLPreElement} */ (document.getElementById('event-log'));

    const events = [
      'ai-ready',
      'ai-unavailable',
      'ai-download-start',
      'ai-download-progress',
      'ai-download-complete',
      'ai-download-error',
      'ai-field-extracted',
      'ai-conversation-update',
      'ai-no-match',
      'ai-error',
      'ai-validation-start',
      'ai-validation-passed',
      'ai-validation-failed',
      'voice-transcript',
      'voice-start',
      'voice-end',
      'voice-error',
      'voice-unavailable',
    ];

    /** @type {string[]} */
    const lines = [];
    /** @param {string} name @param {any} detail */
    function append(name, detail) {
      const time = new Date().toLocaleTimeString();
      const serialized = detail ? JSON.stringify(detail, replaceError) : '';
      lines.unshift(`[${time}] ${name}${serialized ? ' ' + serialized : ''}`);
      if (lines.length > 100) lines.length = 100;
      log.textContent = lines.join('\n');
    }

    /** @param {string} _k @param {unknown} v */
    function replaceError(_k, v) {
      if (v instanceof Error) return { name: v.name, message: v.message };
      if (v instanceof Element) return `<${v.tagName.toLowerCase()}>`;
      return v;
    }

    for (const evt of events) {
      form.addEventListener(evt, (/** @type {CustomEvent} */ e) => append(evt, e.detail));
    }

    form.addEventListener('submit', () => append('submit', { ok: true }));
  </script>
</BaseLayout>
