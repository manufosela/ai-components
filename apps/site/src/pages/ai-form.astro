---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="<ai-form> playground">
  <section>
    <h1><code>&lt;ai-form&gt;</code> — live playground</h1>
    <p>
      Open this page in <strong>Chrome 138+ with the Built-in AI flags enabled</strong>
      (<a
        href="https://developer.chrome.com/docs/ai/get-started"
        target="_blank"
        rel="noopener noreferrer">requirements & setup</a
      >). The component detects capability on mount:
    </p>
    <ul>
      <li>
        <strong>AI available</strong> → conversational chat UI above the form. Type or dictate your
        data; the AI fills the fields live. The <em>Submit</em> button appears only when every
        <code>required</code> field is satisfied.
      </li>
      <li>
        <strong>AI downloadable</strong> → chat UI is rendered but disabled; banner with
        <em>Enable AI</em> triggers the one-time Gemini Nano download (~2 GB).
      </li>
      <li>
        <strong>AI downloading</strong> → banner with live progress bar; chat stays disabled until
        it finishes.
      </li>
      <li>
        <strong>AI unsupported</strong> → native HTML5 form with a small explanatory notice.
      </li>
    </ul>
    <p>
      Fields tagged with <code>ai-extract</code> are filled by the AI. Everything else (file inputs,
      checkboxes, <code>&lt;select&gt;</code>, dates…) is <em>manual</em>; the chat prompt reminds
      the user about them.
    </p>
  </section>

  <section>
    <h2>Demo form</h2>

    <div class="toolbar-row card">
      <label>
        <input type="checkbox" id="toggle-voice-input" checked />
        <code>voice-input</code>
      </label>
      <label>
        <input type="checkbox" id="toggle-voice-output" checked />
        <code>voice-output</code>
      </label>
      <button type="button" id="clear-log">Clear event log</button>
    </div>

    <ai-form id="demo" language="es-ES" voice-input voice-output>
      <form>
        <label>
          <span>Nombre</span>
          <input
            name="nombre"
            ai-extract="nombre completo"
            ai-validate="at least two words, no digits"
            required
          />
        </label>
        <label>
          <span>Teléfono</span>
          <input
            name="telefono"
            type="tel"
            ai-extract="número de móvil"
            ai-validate="spanish mobile (9 digits, starting with 6 or 7)"
            required
          />
        </label>
        <label>
          <span>Email</span>
          <input name="email" type="email" ai-extract="dirección de email" />
        </label>
        <label>
          <span>Comentario</span>
          <textarea
            name="about"
            ai-extract="comentario libre"
            ai-validate="tono profesional, máximo 200 palabras"
            rows="3"></textarea>
        </label>
        <label>
          <span>CV (PDF)</span>
          <input name="cv" type="file" accept="application/pdf" required />
        </label>
        <label class="inline">
          <input name="tos" type="checkbox" required />
          <span>Acepto los términos</span>
        </label>
        <div class="actions">
          <button type="reset">Reset</button>
        </div>
      </form>
    </ai-form>
  </section>

  <section>
    <h2>Event log</h2>
    <p>
      Everything the component emits. Bubbled and <code>composed: true</code>, so this page catches
      them all.
    </p>
    <pre id="event-log" aria-live="polite">(waiting for capability detection…)</pre>
  </section>

  <section>
    <h2>Try dictating or typing this</h2>
    <p>In the chat textarea, paste or dictate:</p>
    <pre><code>Soy Juan Pérez, móvil 666 12 34 56 y juan.perez@example.com. Quiero destacar mi experiencia con equipos técnicos.</code></pre>
    <p>
      The Prompt API should extract structured JSON that fills <code>nombre</code>,
      <code>telefono</code>, <code>email</code> and <code>about</code>. You still have to attach
      the CV file and tick the TOS checkbox before <em>Submit</em> appears — that's the "manual
      fields" reminder in the dynamic prompt.
    </p>
  </section>

  <style>
    section {
      margin-bottom: 2rem;
    }
    .toolbar-row {
      display: flex;
      flex-wrap: wrap;
      gap: 1rem;
      align-items: center;
      margin-bottom: 0.75rem;
    }
    ai-form form {
      display: grid;
      gap: 0.75rem;
      padding: 1rem;
      border: 1px solid var(--border);
      border-radius: 8px;
      background: var(--card);
    }
    ai-form label {
      display: grid;
      gap: 0.25rem;
    }
    ai-form label.inline {
      display: flex;
      flex-direction: row;
      align-items: center;
      gap: 0.5rem;
    }
    ai-form label span {
      font-size: 0.9rem;
      color: var(--muted);
    }
    ai-form input,
    ai-form textarea {
      font: inherit;
      padding: 0.4rem 0.5rem;
      border: 1px solid var(--border);
      border-radius: 4px;
      background: var(--bg);
      color: var(--fg);
    }
    ai-form input:invalid,
    ai-form textarea:invalid {
      border-color: var(--danger);
    }
    .actions {
      display: flex;
      gap: 0.5rem;
    }
    button {
      appearance: none;
      border: 1px solid var(--border);
      background: var(--card);
      color: var(--fg);
      padding: 0.4rem 0.8rem;
      border-radius: 4px;
      cursor: pointer;
      font: inherit;
    }
    button[type='submit'] {
      border-color: var(--accent);
      color: var(--accent);
    }
  </style>

  <script>
    import '@manufosela/ai-form';

    const form = /** @type {any} */ (document.getElementById('demo'));
    const log = /** @type {HTMLPreElement} */ (document.getElementById('event-log'));
    const toggleIn = /** @type {HTMLInputElement} */ (
      document.getElementById('toggle-voice-input')
    );
    const toggleOut = /** @type {HTMLInputElement} */ (
      document.getElementById('toggle-voice-output')
    );
    const clear = /** @type {HTMLButtonElement} */ (document.getElementById('clear-log'));

    const events = [
      'ai-ready',
      'ai-unavailable',
      'ai-download-start',
      'ai-download-progress',
      'ai-download-complete',
      'ai-download-error',
      'ai-field-extracted',
      'ai-conversation-update',
      'ai-no-match',
      'ai-error',
      'ai-validation-start',
      'ai-validation-passed',
      'ai-validation-failed',
      'voice-transcript',
      'voice-start',
      'voice-end',
      'voice-error',
      'voice-unavailable',
    ];

    /** @type {string[]} */
    const lines = [];
    /** @param {string} name @param {any} detail */
    function append(name, detail) {
      const time = new Date().toLocaleTimeString();
      const serialized = detail ? JSON.stringify(detail, replaceError, 2) : '';
      lines.unshift(`[${time}] ${name}${serialized ? ' ' + serialized : ''}`);
      if (lines.length > 100) lines.length = 100;
      log.textContent = lines.join('\n');
    }

    /** @param {string} _k @param {unknown} v */
    function replaceError(_k, v) {
      if (v instanceof Error) return { name: v.name, message: v.message };
      if (v instanceof Element) return `<${v.tagName.toLowerCase()}>`;
      return v;
    }

    for (const evt of events) {
      form.addEventListener(evt, (/** @type {CustomEvent} */ e) => append(evt, e.detail));
    }

    toggleIn.addEventListener('change', () => {
      form.toggleAttribute('voice-input', toggleIn.checked);
    });
    toggleOut.addEventListener('change', () => {
      form.toggleAttribute('voice-output', toggleOut.checked);
    });
    clear.addEventListener('click', () => {
      lines.length = 0;
      log.textContent = '(cleared)';
    });
  </script>
</BaseLayout>
